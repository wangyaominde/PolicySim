# Copy to .env.local and fill in your own values (.env.local is gitignored).
# Anthropic-compatible API key (Anthropic, MiniMax, etc.)
VITE_API_KEY=your-api-key-here
# API base URL. For MiniMax use https://api.minimaxi.com/anthropic
# (in dev this is proxied via /api/ai to avoid CORS). For Anthropic use https://api.anthropic.com
VITE_API_BASE_URL=https://api.minimaxi.com/anthropic
# Model id, e.g. MiniMax-M3 (1M context) or claude-sonnet-4-20250514
VITE_MODEL=MiniMax-M3
